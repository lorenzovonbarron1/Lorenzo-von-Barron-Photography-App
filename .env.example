# LYNK submission delivery (Supabase).
# Create the table with supabase/lynk_submissions.sql, then copy
# these from Supabase → Project Settings → API. Both are safe to
# expose to the browser: RLS limits the anon key to insert-only.
# Leave unset to keep submissions local-only (previous behavior).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
